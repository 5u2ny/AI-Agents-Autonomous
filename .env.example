# No API key needed — these agents run on whatever coding-agent CLI you're
# already logged into. Everything below is OPTIONAL.

# Force a specific coding agent (otherwise the first one found is used).
# One of: claude | codex | gemini | copilot | cursor-agent | opencode | aider
# CODING_AGENT=claude

# Use any other coding agent by giving its headless command. Include {prompt}
# where the task text should go (or it is appended as the last argument).
# CODING_AGENT_CMD=mytool run --yes {prompt}

# Max seconds to let an agent run before timing out.
# AGENT_TIMEOUT=1800
