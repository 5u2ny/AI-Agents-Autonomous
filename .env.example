# No API key needed — these agents run on your Claude subscription via the
# Claude Agent SDK. Just run `claude login` once (Pro / Max / Team plan).
#
# Everything below is OPTIONAL.

# Pin a specific model (otherwise your subscription default is used).
# AGENT_MODEL=claude-sonnet-4-6

# Max autonomous turns before the agent must wrap up.
# AGENT_MAX_TURNS=30
